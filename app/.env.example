# .env.example — copy to .env for local development
# Never commit .env to git

RACK_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost/app_development
SECRET_KEY_BASE=change_me_to_a_random_64_char_hex_string
ALLOWED_ORIGINS=http://localhost:3000
APP_NAME=ruby-api
WEB_CONCURRENCY=2
DB_POOL=5
